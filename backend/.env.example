# Earthbucks API — environment configuration
# Copy this file to .env and fill in real values.

# SQLite for local dev. Swap for postgresql+psycopg://user:pw@host/db in prod.
DATABASE_URL=sqlite:///./earthbucks.db

# JWT secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=J62uCae72ar
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,http://127.0.0.1:5500
