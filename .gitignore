# ── Earthbucks .gitignore (project root) ─────────────────────────

# Python (backend/)
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.alembic_cache/

# SQLite databases (don't commit local DB state)
*.db
*.sqlite
*.sqlite3

# Environment / secrets
.env
.env.local
.env.*.local

# Node (frontend/)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
*.tsbuildinfo

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
